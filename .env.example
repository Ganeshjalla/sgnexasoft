# SGNexasoft Environment Variables
# Copy this to .env and fill in your values
# NEVER commit the actual .env file to git

# ── Backend ──────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/sgnexasoft_db?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=sguser
SPRING_DATASOURCE_PASSWORD=Ganesh@03

APP_JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
APP_JWT_EXPIRATION=86400000

APP_UPLOAD_DIR=uploads/

# ── Frontend ─────────────────────────────────────────────
REACT_APP_API_URL=https://your-backend-domain.com

# ── Docker (docker-compose) ───────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_USER=sguser
MYSQL_PASSWORD=Ganesh@03

# ── GitHub Actions Secrets to set ────────────────────────
# VPS_HOST        = your server IP
# VPS_USER        = ubuntu
# VPS_SSH_KEY     = your private SSH key
# DOCKER_USERNAME = your Docker Hub username
# DOCKER_PASSWORD = your Docker Hub password or token
# REACT_APP_API_URL = https://your-domain.com
